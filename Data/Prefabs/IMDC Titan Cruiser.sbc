              <SubtypeName>LargeProgrammableBlock</SubtypeName>
              <EntityId>84429555268164642</EntityId>
              <Min x="-3" y="4" z="15" />
              <ColorMaskHSV x="0" y="-0.96" z="-0.39" />
              <ShareMode>Faction</ShareMode>
              <CustomName>Problock 4 Floor Plan</CustomName>
              <ShowOnHUD>false</ShowOnHUD>
              <ShowInTerminal>true</ShowInTerminal>
              <ShowInToolbarConfig>true</ShowInToolbarConfig>
              <ShowInInventory>true</ShowInInventory>
              <NumberInGrid>0</NumberInGrid>
              <Enabled>true</Enabled>
              <Program>const string strDisplayPanel = "L_PANEL";
//const string strStatusPanel = "L_STATUS";

//If set to more than one for any of the both values, Multiple Display Mode is activated
//For Multiple Display Mode, the following setup MUST be followed:
//
//    1) Top Left Most Text Panel must be named &lt;strDisplayPanel&gt; (Default is L_PANEL)
//    2) Text Panels MUST be placed side by side in a grid layout, according to the &lt;displayPanelHorizontalCount&gt; and &lt;displayPanelVerticalCount&gt;. No naming is required as it is auto detected
//    3) All Text Panels MUST be of the same type
//    
int displayPanelHorizontalCount = 1;
int displayPanelVerticalCount = 1;

bool boolPaintDensity = true;
bool boolPaintTerminalBlocks = true;
bool boolPaintAlertBlocks = true;

bool boolBlinkForAlert = false;         //true = show blinking for alert. false = show static solid box for alert. This is mainly for performance purposes
bool boolUseRelativeDensity = false;    //true = calculate density based on how much gap there is, false = calculate density based how many blocks are occupying that screen pixel

const char chrBackground = darkGray;
const char chrStructure = lightGray;
const char chrDensity = mediumGray;
const char chrLowDensity = dimGray;

const char chrDetectedEntity = red;

const char chrMissingBlock = red;
const char chrAlertBlock = yellow;

float densityThreshold = 0.5f;
float lowDensityThreshold = 0.25f;

const char chrTerminalBlockFunctional = green;
const char chrTerminalBlockDamaged = yellow;
const char chrTerminalBlockMissing = red;

const int PIXEL_SIZE = 1;
const int REFRESH_INTERVAL = 15;

//------------------------------ Standard Constants ------------------------------

const float INSTRUCTION_PERCENT_LIMIT = 0.9f;

const int TEXT_MAX_RESOLUTION_X = 160;
const int TEXT_MAX_RESOLUTION_Y = 177;

const int WIDE_LCD_MAX_RESOLUTION_X = 321;
const int WIDE_LCD_MAX_RESOLUTION_Y = 178;

//------------------------------ Color Code Constants ------------------------------

//Credits to alex-thatradarguy for finding these characters
//http://steamcommunity.com/sharedfiles/filedetails/?id=627416824
const char green = '\uE001';
const char blue  = '\uE002';
const char red   = '\uE003';
const char yellow = '\uE004';
const char white = '\uE006';
const char lightGray = '\uE00E';
const char mediumGray = '\uE00D';
const char darkGray = '\uE00F';
const char dimGray = '\uE017';

//------------------------------ Script Compound Parameters ------------------------------

const byte SUB_X = 32;
const byte ADD_X = 16;
const byte SUB_Y = 8;
const byte ADD_Y = 4;
const byte SUB_Z = 2;
const byte ADD_Z = 1;

Vector3I[] ADJACENT_VECTORS = { new Vector3I(-1, 0, 0), new Vector3I(1, 0, 0), new Vector3I(0, -1, 0), new Vector3I(0, 1, 0), new Vector3I(0, 0, -1), new Vector3I(0, 0, 1) };
byte [] ADJACENT_MASKS = new byte[6];

HashSet&lt;string&gt; WATCH_BLOCK_LOOKUP = null;

HashSet&lt;string&gt; FIXED_GRID_ADJUST_CMD = null;
HashSet&lt;string&gt; RELATIVE_GRID_ADJUST_CMD = null;

//------------------------------ Below Is Main Script Body ------------------------------

IMyTextPanel displayPanel = null;
IMyTextPanel[][] displayPanels = null;
//IMyTextPanel statusPanel = null;
bool multiplePanels = false;

Dictionary&lt;Vector3I, byte&gt; structureBlocks = null;
Stack&lt;Vector3I&gt; searchRemainingCubes = null;
HashSet&lt;Vector3I&gt; searchTestedCubes = null;

List&lt;KeyValuePair&lt;Vector3I, byte&gt;&gt; structureDataList = null;
List&lt;KeyValuePair&lt;Vector3I, byte&gt;&gt; structureTempList = null;

List&lt;IMyTerminalBlock&gt; terminalBlocks = null;
Dictionary&lt;Vector4I, int&gt; priorityTerminalDrawn = null;
List&lt;Vector4I&gt; damagedTerminalBlocks = null;
List&lt;Vector4I&gt; criticalTerminalBlocks = null;

List&lt;IMyTerminalBlock&gt; watchedBlocks = null;
HashSet&lt;Vector2I&gt; drawnPositions = null;

int gridAxisX = 4;      //0 = Grid X Positive, 1 = Grid X Negative, 2 = Grid Y Positive, 3 = Grid Y Negative, 4 = Grid Z Positive, 5 = Grid Z Negative
int gridAxisY = 1;      //0 = Grid X Positive, 1 = Grid X Negative, 2 = Grid Y Positive, 3 = Grid Y Negative, 4 = Grid Z Positive, 5 = Grid Z Negative
int gridStartX = 0;
int gridEndX = 0;
int gridStartY = 0;
int gridEndY = 0;
int gridStartZ = 0;
int gridEndZ = 0;
int gridWidthX = 0;
int gridWidthY = 0;
int gridWidthZ = 0;

int axisWidthX = 0;
int axisWidthY = 0;
int axisWidthZ = 0;

Base6Directions.Axis gridAxisXDirection = Base6Directions.Axis.ForwardBackward;
Base6Directions.Axis gridAxisYDirection = Base6Directions.Axis.LeftRight;
Base6Directions.Axis gridAxisZDirection = Base6Directions.Axis.UpDown;
Vector3I gridMin = new Vector3I();
Vector3I gridMax = new Vector3I();
bool gridReverseX = false;
bool gridReverseY = true;
int gridOffsetPosX = 0;
int gridOffsetPosY = 0;

char[][] structureBase = null;
int screenWidthX = 0;
int screenWidthY = 0;
int screenOffsetX = 0;
int screenOffsetY = 0;
int screenBlockSizeX = 0;
int screenBlockSizeY = 0;
Vector3I[][] structureDensity = null;

char[][] renderData = null;

string previousDisplayParameters = "";

bool isBlinkFrame = false;

int subCounter = 0;
int subMode = -1;
int mode = 0;
int clock = 0;
bool init = false;

void Main(string arguments)
{
    if (!init)
    {
        if (subMode == -1)
        {
            displayPanelHorizontalCount = Math.Max(displayPanelHorizontalCount, 1);
            displayPanelVerticalCount = Math.Max(displayPanelVerticalCount, 1);
            
            ADJACENT_MASKS[0] = SUB_X;
            ADJACENT_MASKS[1] = ADD_X;
            ADJACENT_MASKS[2] = SUB_Y;
            ADJACENT_MASKS[3] = ADD_Y;
            ADJACENT_MASKS[4] = SUB_Z;
            ADJACENT_MASKS[5] = ADD_Z;
            
            WATCH_BLOCK_LOOKUP = new HashSet&lt;string&gt;();
            WATCH_BLOCK_LOOKUP.Add("Air Vent");
            WATCH_BLOCK_LOOKUP.Add("Interior Turret");
            WATCH_BLOCK_LOOKUP.Add("Gatling Turret");
            WATCH_BLOCK_LOOKUP.Add("Missile Turret");
            WATCH_BLOCK_LOOKUP.Add("Sensor");

            FIXED_GRID_ADJUST_CMD = new HashSet&lt;string&gt;();
            FIXED_GRID_ADJUST_CMD.Add("X1+");
            FIXED_GRID_ADJUST_CMD.Add("X1-");
            FIXED_GRID_ADJUST_CMD.Add("X2+");
            FIXED_GRID_ADJUST_CMD.Add("X2-");
            FIXED_GRID_ADJUST_CMD.Add("Y1+");
            FIXED_GRID_ADJUST_CMD.Add("Y1-");
            FIXED_GRID_ADJUST_CMD.Add("Y2+");
            FIXED_GRID_ADJUST_CMD.Add("Y2-");
            FIXED_GRID_ADJUST_CMD.Add("Z1+");
            FIXED_GRID_ADJUST_CMD.Add("Z1-");
            FIXED_GRID_ADJUST_CMD.Add("Z2+");
            FIXED_GRID_ADJUST_CMD.Add("Z2-");

            RELATIVE_GRID_ADJUST_CMD = new HashSet&lt;string&gt;();
            RELATIVE_GRID_ADJUST_CMD.Add("PLUS_LEFT");
            RELATIVE_GRID_ADJUST_CMD.Add("MINUS_LEFT");
            RELATIVE_GRID_ADJUST_CMD.Add("PLUS_RIGHT");
            RELATIVE_GRID_ADJUST_CMD.Add("MINUS_RIGHT");
            RELATIVE_GRID_ADJUST_CMD.Add("PLUS_UP");
            RELATIVE_GRID_ADJUST_CMD.Add("MINUS_UP");
            RELATIVE_GRID_ADJUST_CMD.Add("PLUS_DOWN");
            RELATIVE_GRID_ADJUST_CMD.Add("MINUS_DOWN");
            RELATIVE_GRID_ADJUST_CMD.Add("PLUS_FORWARD");
            RELATIVE_GRID_ADJUST_CMD.Add("MINUS_FORWARD");
            RELATIVE_GRID_ADJUST_CMD.Add("PLUS_BACKWARD");
            RELATIVE_GRID_ADJUST_CMD.Add("MINUS_BACKWARD");
            RELATIVE_GRID_ADJUST_CMD.Add("PAN_LEFT");
            RELATIVE_GRID_ADJUST_CMD.Add("PAN_RIGHT");
            RELATIVE_GRID_ADJUST_CMD.Add("PAN_UP");
            RELATIVE_GRID_ADJUST_CMD.Add("PAN_DOWN");
            RELATIVE_GRID_ADJUST_CMD.Add("PAN_FORWARD");
            RELATIVE_GRID_ADJUST_CMD.Add("PAN_BACKWARD");

            subMode = 0;
        }
        
        if (subMode == 0)
        {
            if (displayPanelHorizontalCount + displayPanelVerticalCount == 2)
            {
                displayPanels = null;
                InitDisplayPanel();
                multiplePanels = false;
            }
            else
            {
                InitDisplayPanels();
                multiplePanels = true;
            }
            
            //statusPanel = GridTerminalSystem.GetBlockWithName(strStatusPanel) as IMyTextPanel;
            
            structureBlocks = new Dictionary&lt;Vector3I, byte&gt;();
            searchRemainingCubes = new Stack&lt;Vector3I&gt;();
            searchTestedCubes = new HashSet&lt;Vector3I&gt;();

            structureBlocks.Add(Me.Position, 0);
            searchRemainingCubes.Push(Me.Position);
            searchTestedCubes.Add(Me.Position);

            subMode = 1;
            return;
        }
        else if (subMode == 1)
        {
            if (InitStructureData(Me.CubeGrid, searchRemainingCubes, structureBlocks, searchTestedCubes, INSTRUCTION_PERCENT_LIMIT))
            {
                subMode = 2;
            }
            return;
        }
        else if (subMode == 2)
        {
            searchRemainingCubes = null;
            searchTestedCubes = null;
            
            InitTerminalBlocks();
            subMode = 3;
            return;
        }
        else if (subMode == 3)
        {
            gridStartX = Me.CubeGrid.Min.X;
            gridEndX = Me.CubeGrid.Max.X;
            gridStartY = Me.CubeGrid.Min.Y;
            gridEndY = Me.CubeGrid.Max.Y;
            gridStartZ = Me.CubeGrid.Min.Z;
            gridEndZ = Me.CubeGrid.Max.Z;
            gridWidthX = gridEndX - gridStartX + 1;
            gridWidthY = gridEndY - gridStartY + 1;
            gridWidthZ = gridEndZ - gridStartZ + 1;

            ProcessDisplayParameters(displayPanel.GetPublicTitle());
            previousDisplayParameters = displayPanel.GetPublicTitle();
            
            if (previousDisplayParameters.Length == 0)
            {
                WriteDisplayParameters();
            }

            InitScreenParameters();
            
            if (FilteringRequired())
            {
                structureTempList = new List&lt;KeyValuePair&lt;Vector3I, byte&gt;&gt;(structureBlocks);
                structureDataList = new List&lt;KeyValuePair&lt;Vector3I, byte&gt;&gt;();
                
                subCounter = 0;
                subMode = 4;
            }
            else
            {
                structureDataList = new List&lt;KeyValuePair&lt;Vector3I, byte&gt;&gt;(structureBlocks);
                
                subCounter = 0;
                subMode = 5;
            }

            watchedBlocks = new List&lt;IMyTerminalBlock&gt;();

            return;
        }
        else if (subMode == 4)
        {
            subCounter = FilterStructureData(Me.CubeGrid, structureTempList, structureDataList, subCounter, INSTRUCTION_PERCENT_LIMIT);
            if (subCounter &gt;= structureTempList.Count)
            {
                structureTempList = null;
                
                subCounter = 0;
                subMode = 5;
            }
            return;
        }
        else if (subMode == 5)
        {
            subCounter = FilterWatchedBlocks(Me.CubeGrid, terminalBlocks, watchedBlocks, subCounter, INSTRUCTION_PERCENT_LIMIT);
            if (subCounter &gt;= terminalBlocks.Count)
            {
                subCounter = 0;
                subMode = (boolPaintDensity ? 6 : 8);
            }
            return;
        }
        else if (subMode == 6)
        {
            subCounter = ComputeStructureDensity(structureDataList, subCounter, INSTRUCTION_PERCENT_LIMIT);
            if (subCounter &gt;= structureDataList.Count)
            {
                subCounter = 0;
                subMode = 7;
            }
            return;
        }
        else if (subMode == 7)
        {
            subCounter = PaintStructureDensity(structureDensity, subCounter, INSTRUCTION_PERCENT_LIMIT);
            if (subCounter &gt;= axisWidthY * axisWidthX)
            {
                subCounter = 0;
                subMode = 8;
            }
            return;
        }
        else if (subMode == 8)
        {
            subCounter = PaintStructureBase(structureDataList, subCounter, INSTRUCTION_PERCENT_LIMIT);
            if (subCounter &gt;= structureDataList.Count)
            {
                subMode = 9;
            }
            return;
        }
        else if (subMode == 9)
        {
            renderData = new char[structureBase.Length][];
            for (int i = 0; i &lt; screenWidthY; i++)
            {
                renderData[i] = new char[structureBase[i].Length];
                Array.Copy(structureBase[i], renderData[i], structureBase[i].Length);
            }

            priorityTerminalDrawn = new Dictionary&lt;Vector4I, int&gt;();
            damagedTerminalBlocks = new List&lt;Vector4I&gt;();
            criticalTerminalBlocks = new List&lt;Vector4I&gt;();

            subCounter = 0;
            subMode = (boolPaintTerminalBlocks ? 10 : 12);
        }
        else if (subMode == 10)
        {
            subCounter = PaintGoodTerminalBlocks(renderData, Me.CubeGrid, terminalBlocks, priorityTerminalDrawn, damagedTerminalBlocks, criticalTerminalBlocks, subCounter, INSTRUCTION_PERCENT_LIMIT);
            if (subCounter &gt;= terminalBlocks.Count)
            {
                priorityTerminalDrawn = null;

                subCounter = 0;

                if (damagedTerminalBlocks.Count + criticalTerminalBlocks.Count == 0)
                {
                    damagedTerminalBlocks = null;
                    criticalTerminalBlocks = null;

                    subMode = 12;
                }
                else
                {
                    subMode = 11;
                }
            }
            return;
        }
        else if (subMode == 11)
        {
            subCounter = PaintBadTerminalBlocks(renderData, Me.CubeGrid, damagedTerminalBlocks, criticalTerminalBlocks, subCounter, INSTRUCTION_PERCENT_LIMIT);
            if (subCounter &gt;= damagedTerminalBlocks.Count + criticalTerminalBlocks.Count)
            {
                damagedTerminalBlocks = null;
                criticalTerminalBlocks = null;
                
                subCounter = 0;
                subMode = 12;
            }
            return;
        }

        subCounter = 0;
        subMode = 0;
        mode = 0;

        clock = 0;

        init = true;
        return;
    }

    clock++;
    
    if (arguments != null &amp;&amp; arguments.Length &gt; 0)
    {
        arguments = arguments.Trim().ToUpper();
        
        if (arguments.Equals("REDRAW"))         //Redraw The Floor Plan With The New Set Of Screen Parameters
        {
            if (!previousDisplayParameters.Equals(displayPanel.GetPublicTitle()) &amp;&amp; ProcessDisplayParameters(displayPanel.GetPublicTitle()))
            {
                previousDisplayParameters = displayPanel.GetPublicTitle();
                
                ResetStructureBase();
                RedrawStructure();
                
                return;
            }
        }
        else if (arguments.Equals("RESET"))     //Reset The Whole Script And Recalculate All Blocks Again
        {
            subCounter = 0;
            subMode = 0;
            mode = 0;
            
            init = false;
            return;
        }
        else if (arguments.Equals("DENSE"))
        {
            boolPaintDensity = true;
            
            WriteDisplayParameters();
            ResetStructureBase();
            RedrawStructure();

            return;
        }
        else if (arguments.Equals("NO_DENSE"))
        {
            boolPaintDensity = false;
            
            WriteDisplayParameters();
            ResetStructureBase();
            RedrawStructure();

            return;
        }
        else if (arguments.Equals("TOGGLE_DENSE"))
        {
            boolPaintDensity = !boolPaintDensity;
            
            WriteDisplayParameters();
            ResetStructureBase();
            RedrawStructure();

            return;
        }
        else if (arguments.Equals("RELDENSE"))
        {
            boolUseRelativeDensity = true;
            
            WriteDisplayParameters();
            ResetStructureBase();
            RedrawStructure();

            return;
        }
        else if (arguments.Equals("NO_RELDENSE"))
        {
            boolUseRelativeDensity = false;
            
            WriteDisplayParameters();
            ResetStructureBase();
            RedrawStructure();

            return;
        }
        else if (arguments.Equals("TOGGLE_RELDENSE"))
        {
            boolUseRelativeDensity = !boolUseRelativeDensity;
            
            WriteDisplayParameters();
            ResetStructureBase();
            RedrawStructure();

            return;
        }
        else if (arguments.Equals("TERM"))
        {
            boolPaintTerminalBlocks = true;
            
            WriteDisplayParameters();
            RedrawStructure();

            return;
        }
        else if (arguments.Equals("NO_TERM"))
        {
            boolPaintTerminalBlocks = false;
            
            WriteDisplayParameters();
            RedrawStructure();

            return;
        }
        else if (arguments.Equals("TOGGLE_TERM"))
        {
            boolPaintTerminalBlocks = !boolPaintTerminalBlocks;
            
            WriteDisplayParameters();
            RedrawStructure();

            return;
        }
        else if (arguments.Equals("ALERT"))
        {
            boolPaintAlertBlocks = true;
            
            WriteDisplayParameters();
            RedrawStructure();

            return;
        }
        else if (arguments.Equals("NO_ALERT"))
        {
            boolPaintAlertBlocks = false;
            
            WriteDisplayParameters();
            RedrawStructure();

            return;
        }
        else if (arguments.Equals("TOGGLE_ALERT"))
        {
            boolPaintAlertBlocks = !boolPaintAlertBlocks;
            
            WriteDisplayParameters();
            RedrawStructure();

            return;
        }
        else if (arguments.Equals("BLINK"))
        {
            boolBlinkForAlert = true;
            
            WriteDisplayParameters();
            
            return;
        }
        else if (arguments.Equals("NO_BLINK"))
        {
            boolBlinkForAlert = false;
            
            WriteDisplayParameters();

            return;
        }
        else if (arguments.Equals("TOGGLE_BLINK"))
        {
            boolBlinkForAlert = !boolBlinkForAlert;
            
            WriteDisplayParameters();

            return;
        }
        else if (FIXED_GRID_ADJUST_CMD.Contains(arguments) || RELATIVE_GRID_ADJUST_CMD.Contains(arguments))
        {
            bool isRelative = RELATIVE_GRID_ADJUST_CMD.Contains(arguments);
            char axisCode;
            bool isStart;
            bool isPositive;
            bool isPan;

            if (isRelative)
            {
                string[] token = arguments.Split('_');
                Base6Directions.Axis axisDirection;

                isPan = token[0].Equals("PAN");

                if (isPan)
                {
                    isPositive = ("RIGHT,DOWN,BACKWARD".Contains(token[1]));
                }
                else
                {
                    isPositive = token[0].Equals("PLUS");
                }
                
                switch (token[1])
                {
                    case "LEFT":
                        isStart = !gridReverseX;
                        isPositive = (gridReverseX ? !isPositive : isPositive);
                        axisDirection = gridAxisXDirection;
                        break;
                    case "RIGHT":
                        isStart = gridReverseX;
                        isPositive = (gridReverseX ? !isPositive : isPositive);
                        axisDirection = gridAxisXDirection;
                        break;
                    case "UP":
                        isStart = !gridReverseY;
                        isPositive = (gridReverseY ? !isPositive : isPositive);
                        axisDirection = gridAxisYDirection;
                        break;
                    case "DOWN":
                        isStart = gridReverseY;
                        isPositive = (gridReverseY ? !isPositive : isPositive);
                        axisDirection = gridAxisYDirection;
                        break;
                    case "FORWARD":
                        Base6Directions.Direction directionZ1 = Base6Directions.GetCross(GetAxisDirection(gridAxisXDirection, gridReverseX), GetAxisDirection(gridAxisYDirection, gridReverseY));
                        isStart = (directionZ1 == Base6Directions.Direction.Right || directionZ1 == Base6Directions.Direction.Down || directionZ1 == Base6Directions.Direction.Backward);
                        isPositive = (isStart ? isPositive : !isPositive);
                        axisDirection = gridAxisZDirection;
                        break;
                    case "BACKWARD":
                        Base6Directions.Direction directionZ2 = Base6Directions.GetCross(GetAxisDirection(gridAxisXDirection, gridReverseX), GetAxisDirection(gridAxisYDirection, gridReverseY));
                        isStart = (directionZ2 == Base6Directions.Direction.Left || directionZ2 == Base6Directions.Direction.Up || directionZ2 == Base6Directions.Direction.Forward);
                        isPositive = (isStart ? !isPositive : isPositive);
                        axisDirection = gridAxisZDirection;
                        break;
                    default:
                        isStart = !gridReverseX;
                        isPositive = (gridReverseX ? !isPositive : isPositive);
                        axisDirection = gridAxisXDirection;
                        break;
                }
                
                switch (axisDirection)
                {
                    case Base6Directions.Axis.LeftRight:
                        axisCode = 'X';
                        break;
                    case Base6Directions.Axis.UpDown:
                        axisCode = 'Y';
                        break;
                    case Base6Directions.Axis.ForwardBackward:
                        axisCode = 'Z';
                        break;
                    default:
                        axisCode = 'X';
                        break;
                }
            }
            else
            {
                isPan = false;
                axisCode = arguments[0];
                isStart = (arguments[1] == '1');
                isPositive = (arguments[2] == '+');
            }

            bool needRedraw;

            if (axisCode == 'X')
            {
                needRedraw = AdjustGridSize(ref gridStartX, ref gridEndX, Me.CubeGrid.Min.X, Me.CubeGrid.Max.X, isStart, isPositive, isPan);
            }
            else if (axisCode == 'Y')
            {
                needRedraw = AdjustGridSize(ref gridStartY, ref gridEndY, Me.CubeGrid.Min.Y, Me.CubeGrid.Max.Y, isStart, isPositive, isPan);
            }
            else
            {
                needRedraw = AdjustGridSize(ref gridStartZ, ref gridEndZ, Me.CubeGrid.Min.Z, Me.CubeGrid.Max.Z, isStart, isPositive, isPan);
            }

            if (needRedraw)
            {
                WriteDisplayParameters();
                ResetStructureBase();
                RedrawStructure();
            }

            return;
        }
        else if (arguments.Equals("ZOOM_IN") || arguments.Equals("ZOOM_OUT"))
        {
            int startX;
            int endX;
            int minX;
            int maxX;
            int startY;
            int endY;
            int minY;
            int maxY;
            
            if (gridAxisXDirection == Base6Directions.Axis.LeftRight)
            {
                startX = gridStartX;
                endX = gridEndX;
                minX = Me.CubeGrid.Min.X;
                maxX = Me.CubeGrid.Max.X;
            }
            else if (gridAxisXDirection == Base6Directions.Axis.UpDown)
            {
                startX = gridStartY;
                endX = gridEndY;
                minX = Me.CubeGrid.Min.Y;
                maxX = Me.CubeGrid.Max.Y;
            }
            else
            {
                startX = gridStartZ;
                endX = gridEndZ;
                minX = Me.CubeGrid.Min.Z;
                maxX = Me.CubeGrid.Max.Z;
            }

            if (gridAxisYDirection == Base6Directions.Axis.LeftRight)
            {
                startY = gridStartX;
                endY = gridEndX;
                minY = Me.CubeGrid.Min.X;
                maxY = Me.CubeGrid.Max.X;
            }
            else if (gridAxisYDirection == Base6Directions.Axis.UpDown)
            {
                startY = gridStartY;
                endY = gridEndY;
                minY = Me.CubeGrid.Min.Y;
                maxY = Me.CubeGrid.Max.Y;
            }
            else
            {
                startY = gridStartZ;
                endY = gridEndZ;
                minY = Me.CubeGrid.Min.Z;
                maxY = Me.CubeGrid.Max.Z;
            }

            bool needRedraw;

            if (arguments.Equals("ZOOM_IN"))
            {
                startX++;
                endX--;
                startY++;
                endY--;

                needRedraw = (startX &lt;= endX &amp;&amp; startY &lt;= endY);
            }
            else
            {
                startX--;
                endX++;
                startY--;
                endY++;

                needRedraw = (startX &gt;= minX &amp;&amp; endX &lt;= maxX &amp;&amp; startY &gt;= minY &amp;&amp; endY &lt;= maxY);
            }

            if (needRedraw)
            {
                if (gridAxisXDirection == Base6Directions.Axis.LeftRight)
                {
                    gridStartX = startX;
                    gridEndX = endX;
                }
                else if (gridAxisXDirection == Base6Directions.Axis.UpDown)
                {
                    gridStartY = startX;
                    gridEndY = endX;
                }
                else
                {
                    gridStartZ = startX;
                    gridEndZ = endX;
                }

                if (gridAxisYDirection == Base6Directions.Axis.LeftRight)
                {
                    gridStartX = startY;
                    gridEndX = endY;
                }
                else if (gridAxisYDirection == Base6Directions.Axis.UpDown)
                {
                    gridStartY = startY;
                    gridEndY = endY;
                }
                else
                {
                    gridStartZ = startY;
                    gridEndZ = endY;
                }
                
                WriteDisplayParameters();
                ResetStructureBase();
                RedrawStructure();
            }

            return;
        }
        else if (arguments.Equals("ZOOM_RESET"))
        {
            gridStartX = Me.CubeGrid.Min.X;
            gridEndX = Me.CubeGrid.Max.X;
            gridStartY = Me.CubeGrid.Min.Y;
            gridEndY = Me.CubeGrid.Max.Y;
            gridStartZ = Me.CubeGrid.Min.Z;
            gridEndZ = Me.CubeGrid.Max.Z;
            gridWidthX = gridEndX - gridStartX + 1;
            gridWidthY = gridEndY - gridStartY + 1;
            gridWidthZ = gridEndZ - gridStartZ + 1;

            WriteDisplayParameters();
            ResetStructureBase();
            RedrawStructure();

            return;
        }
        else if (arguments.Equals("DEFAULT_VIEW"))
        {
            ProcessDisplayParameters(displayPanel.GetPrivateTitle());
            previousDisplayParameters = displayPanel.GetPrivateTitle();

            WriteDisplayParameters();
            ResetStructureBase();
            RedrawStructure();

            return;
        }
        else if (arguments.Equals("FLIP_LEFT"))
        {
            gridAxisX += 2;
            if (gridAxisX &gt; 5)
            {
                gridAxisX = (gridAxisX == 6 ? 1 : 0);
            }
            if ((gridAxisX / 2) == (gridAxisY / 2))
            {
                gridAxisX += 2;
                if (gridAxisX &gt; 5)
                {
                    gridAxisX = (gridAxisX == 6 ? 1 : 0);
                }
            }

            WriteDisplayParameters();
            ResetStructureBase();
            RedrawStructure();

            return;
        }
        else if (arguments.Equals("FLIP_RIGHT"))
        {
            gridAxisX -= 2;
            if (gridAxisX &lt; 0)
            {
                gridAxisX = (gridAxisX == -2 ? 5 : 4);
            }
            if ((gridAxisX / 2) == (gridAxisY / 2))
            {
                gridAxisX -= 2;
                if (gridAxisX &lt; 0)
                {
                    gridAxisX = (gridAxisX == -2 ? 5 : 4);
                }
            }

            WriteDisplayParameters();
            ResetStructureBase();
            RedrawStructure();

            return;
        }
        else if (arguments.Equals("FLIP_UP"))
        {
            gridAxisY += 2;
            if (gridAxisY &gt; 5)
            {
                gridAxisY = (gridAxisY == 6 ? 1 : 0);
            }
            if ((gridAxisY / 2) == (gridAxisX / 2))
            {
                gridAxisY += 2;
                if (gridAxisY &gt; 5)
                {
                    gridAxisY = (gridAxisY == 6 ? 1 : 0);
                }
            }

            WriteDisplayParameters();
            ResetStructureBase();
            RedrawStructure();

            return;
        }
        else if (arguments.Equals("FLIP_DOWN"))
        {
            gridAxisY -= 2;
            if (gridAxisY &lt; 0)
            {
                gridAxisY = (gridAxisY == -2 ? 5 : 4);
            }
            if ((gridAxisY / 2) == (gridAxisX / 2))
            {
                gridAxisY -= 2;
                if (gridAxisY &lt; 0)
                {
                    gridAxisY = (gridAxisY == -2 ? 5 : 4);
                }
            }

            WriteDisplayParameters();
            ResetStructureBase();
            RedrawStructure();

            return;
        }
        else if (arguments.Equals("SPIN_CW"))
        {
            int tmpGridAxisY = gridAxisY;
            gridAxisY = gridAxisX;
            gridAxisX = (tmpGridAxisY % 2 == 0 ? tmpGridAxisY + 1 : tmpGridAxisY - 1);

            WriteDisplayParameters();
            ResetStructureBase();
            RedrawStructure();

            return;
        }
        else if (arguments.Equals("SPIN_CCW"))
        {
            int tmpGridAxisX = gridAxisX;
            gridAxisX = gridAxisY;
            gridAxisY = (tmpGridAxisX % 2 == 0 ? tmpGridAxisX + 1 : tmpGridAxisX - 1);

            WriteDisplayParameters();
            ResetStructureBase();
            RedrawStructure();

            return;
        }
    }

    if (mode == 0)              //Waiting For Refresh
    {
        if (clock % REFRESH_INTERVAL == 0)
        {
            subMode = 0;
            mode = 1;
        }
    }
    else if (mode == 1)         //Refresh Logic
    {
        if (subMode == 0)       //Create New Render Data
        {
            renderData = new char[structureBase.Length][];
            for (int i = 0; i &lt; screenWidthY; i++)
            {
                renderData[i] = new char[structureBase[i].Length];
                Array.Copy(structureBase[i], renderData[i], structureBase[i].Length);
            }

            isBlinkFrame = (boolBlinkForAlert ? !isBlinkFrame : true);

            subCounter = 0;

            if (boolPaintTerminalBlocks)
            {
                priorityTerminalDrawn = new Dictionary&lt;Vector4I, int&gt;();
                damagedTerminalBlocks = new List&lt;Vector4I&gt;();
                criticalTerminalBlocks = new List&lt;Vector4I&gt;();

                subMode = 1;
            }
            else
            {
                drawnPositions = new HashSet&lt;Vector2I&gt;();

                subMode = 3;
            }
        }
        else if (subMode == 1)  //Paint Good Terminal Block Overlay
        {
            subCounter = PaintGoodTerminalBlocks(renderData, Me.CubeGrid, terminalBlocks, priorityTerminalDrawn, damagedTerminalBlocks, criticalTerminalBlocks, subCounter, INSTRUCTION_PERCENT_LIMIT);
            if (subCounter &gt;= terminalBlocks.Count)
            {
                priorityTerminalDrawn = null;
                
                subCounter = 0;

                if (damagedTerminalBlocks.Count + criticalTerminalBlocks.Count == 0)
                {
                    damagedTerminalBlocks = null;
                    criticalTerminalBlocks = null;

                    drawnPositions = new HashSet&lt;Vector2I&gt;();

                    subMode = 3;
                }
                else
                {
                    subMode = 2;
                }
            }
        }
        else if (subMode == 2)  //Paint Bad Terminal Block Overlay
        {
            subCounter = PaintBadTerminalBlocks(renderData, Me.CubeGrid, damagedTerminalBlocks, criticalTerminalBlocks, subCounter, INSTRUCTION_PERCENT_LIMIT);
            if (subCounter &gt;= damagedTerminalBlocks.Count + criticalTerminalBlocks.Count)
            {
                damagedTerminalBlocks = null;
                criticalTerminalBlocks = null;
                
                drawnPositions = new HashSet&lt;Vector2I&gt;();

                subCounter = 0;
                subMode = 3;
            }
        }
        else if (subMode == 3)  //Paint Missing Armor Block Overlay
        {
            subCounter = PaintMissingStructure(renderData, Me.CubeGrid, structureDataList, drawnPositions, subCounter, INSTRUCTION_PERCENT_LIMIT);
            if (subCounter &gt;= structureDataList.Count)
            {
                drawnPositions = null;

                subCounter = 0;
                subMode = (boolPaintAlertBlocks &amp;&amp; isBlinkFrame ? 4 : 5);
            }
        }
        else if (subMode == 4)  //Paint Blinking Alert
        {
            subCounter = PaintWatchedBlocks(renderData, Me.CubeGrid, watchedBlocks, subCounter, INSTRUCTION_PERCENT_LIMIT);
            if (subCounter &gt;= watchedBlocks.Count)
            {
                subCounter = 0;
                subMode = 5;
            }
        }
        else
        {
            Render(renderData);
            mode = 0;
        }
    }
}

void RedrawStructure()
{
    gridWidthX = gridEndX - gridStartX + 1;
    gridWidthY = gridEndY - gridStartY + 1;
    gridWidthZ = gridEndZ - gridStartZ + 1;

    InitScreenParameters();
    
    if (FilteringRequired())
    {
        structureTempList = new List&lt;KeyValuePair&lt;Vector3I, byte&gt;&gt;(structureBlocks);
        structureDataList = new List&lt;KeyValuePair&lt;Vector3I, byte&gt;&gt;();
                
        subCounter = 0;
        subMode = 4;
    }
    else
    {
        structureDataList = new List&lt;KeyValuePair&lt;Vector3I, byte&gt;&gt;(structureBlocks);
                
        subCounter = 0;
        subMode = 5;
    }

    watchedBlocks = new List&lt;IMyTerminalBlock&gt;();

    mode = 0;
    
    init = false;
}

void ResetStructureBase()
{
    structureBase = new char[screenWidthY][];
    for (int i = 0; i &lt; screenWidthY; i++)
    {
        structureBase[i] = new char[screenWidthX];
        structureBase[i] = new string(chrBackground, screenWidthX).ToCharArray();
    }
}

Base6Directions.Direction GetAxisDirection(Base6Directions.Axis axis, bool isReverse)
{
    switch (axis)
    {
        case Base6Directions.Axis.LeftRight:
            return (isReverse ? Base6Directions.Direction.Left : Base6Directions.Direction.Right);
        case Base6Directions.Axis.UpDown:
            return (isReverse ? Base6Directions.Direction.Up : Base6Directions.Direction.Down);
        case Base6Directions.Axis.ForwardBackward:
            return (isReverse ? Base6Directions.Direction.Forward : Base6Directions.Direction.Backward);
        default:
            return (isReverse ? Base6Directions.Direction.Left : Base6Directions.Direction.Right);
    }
}

bool AdjustGridSize(ref int gridStart, ref int gridEnd, int gridMinimum, int gridMaximum, bool isStart, bool isPositive, bool isPan)
{
    int tmpGridStart = gridStart;
    int tmpGridEnd = gridEnd;
    
    if (isStart)
    {
        tmpGridStart += (isPositive ? 1 : -1);
        if (isPan)
        {
            tmpGridEnd += (isPositive ? 1 : -1);
        }
    }
    else
    {
        tmpGridEnd += (isPositive ? 1 : -1);
        if (isPan)
        {
            tmpGridStart += (isPositive ? 1 : -1);
        }
    }
    
    if (tmpGridStart &gt; tmpGridEnd || tmpGridStart &lt; gridMinimum || tmpGridEnd &gt; gridMaximum)
    {
        return false;
    }
    
    gridStart = tmpGridStart;
    gridEnd = tmpGridEnd;

    return true;
}

void Render(char[][] drawMap)
{
    if (multiplePanels)
    {
        int singleWidthX = drawMap[0].Length / displayPanelHorizontalCount;
        int singleWidthY = drawMap.Length / displayPanelVerticalCount;
        
        for (int y = 0; y &lt; displayPanelVerticalCount; y++)
        {
            for (int x = 0; x &lt; displayPanelHorizontalCount; x++)
            {
                int startY = y * singleWidthY;
                int endY = startY + singleWidthY;
                int startX = x * singleWidthX;
                StringBuilder sb = new StringBuilder((singleWidthX * singleWidthY) + 1);
                for (int i = startY; i &lt; endY; i++)
                {
                    sb.Append(drawMap[i], startX, singleWidthX).Append('\n');
                }
                displayPanels[y][x].WritePublicText(sb.ToString());
            }
        }
    }
    else
    {
        StringBuilder sb = new StringBuilder((drawMap[0].Length * drawMap.Length) + 1);
        for (int i = 0; i &lt; drawMap.Length; i++)
        {
            sb.Append(drawMap[i]).Append('\n');
        }
        displayPanel.WritePublicText(sb.ToString());
    }
}

//------------------------------ Paramter Processing Methods ------------------------------

bool ProcessDisplayParameters(string paramLine)
{
    paramLine = (paramLine == null ? "" : paramLine.Trim().ToUpper());

    string[] keyValues = paramLine.Split(',');

    int tmpGridAxisX = gridAxisX;
    int tmpGridAxisY = gridAxisY;
    int tmpGridStartX = gridStartX;
    int tmpGridEndX = gridEndX;
    int tmpGridStartY = gridStartY;
    int tmpGridEndY = gridEndY;
    int tmpGridStartZ = gridStartZ;
    int tmpGridEndZ = gridEndZ;

    for (int i = 0; i &lt; keyValues.Length; i++)
    {
        string[] tokens = keyValues[i].Trim().Split(':');
        if (tokens.Length &gt; 0)
        {
            int value;
            string cmdToken = tokens[0].Trim();
            if (cmdToken.Equals("A_X") &amp;&amp; tokens.Length &gt;= 2)
            {
                value = ParseAxisToken(tokens[1]);
                if (value &gt; -1)
                {
                    tmpGridAxisX = value;
                }
            }
            else if (cmdToken.Equals("A_Y") &amp;&amp; tokens.Length &gt;= 2)
            {
                value = ParseAxisToken(tokens[1]);
                if (value &gt; -1)
                {
                    tmpGridAxisY = value;
                }
            }
            else if (cmdToken.Equals("X") &amp;&amp; tokens.Length &gt;= 2)
            {
                if (Int32.TryParse(tokens[1], out value))
                {
                    tmpGridStartX = tmpGridEndX = value;
                }
            }
            else if (cmdToken.Equals("X1") &amp;&amp; tokens.Length &gt;= 2)
            {
                if (Int32.TryParse(tokens[1], out value))
                {
                    tmpGridStartX = value;
                }
            }
            else if (cmdToken.Equals("X2") &amp;&amp; tokens.Length &gt;= 2)
            {
                if (Int32.TryParse(tokens[1], out value))
                {
                    tmpGridEndX = value;
                }
            }
            else if (cmdToken.Equals("Y") &amp;&amp; tokens.Length &gt;= 2)
            {
                if (Int32.TryParse(tokens[1], out value))
                {
                    tmpGridStartY = tmpGridEndY = value;
                }
            }
            else if (cmdToken.Equals("Y1") &amp;&amp; tokens.Length &gt;= 2)
            {
                if (Int32.TryParse(tokens[1], out value))
                {
                    tmpGridStartY = value;
                }
            }
            else if (cmdToken.Equals("Y2") &amp;&amp; tokens.Length &gt;= 2)
            {
                if (Int32.TryParse(tokens[1], out value))
                {
                    tmpGridEndY = value;
                }
            }
            else if (cmdToken.Equals("Z") &amp;&amp; tokens.Length &gt;= 2)
            {
                if (Int32.TryParse(tokens[1], out value))
                {
                    tmpGridStartZ = tmpGridEndZ = value;
                }
            }
            else if (cmdToken.Equals("Z1") &amp;&amp; tokens.Length &gt;= 2)
            {
                if (Int32.TryParse(tokens[1], out value))
                {
                    tmpGridStartZ = value;
                }
            }
            else if (cmdToken.Equals("Z2") &amp;&amp; tokens.Length &gt;= 2)
            {
                if (Int32.TryParse(tokens[1], out value))
                {
                    tmpGridEndZ = value;
                }
            }
            else if (cmdToken.Equals("RELDENSE"))
            {
                boolUseRelativeDensity = true;
            }
            else if (cmdToken.Equals("NO_RELDENSE"))
            {
                boolUseRelativeDensity = false;
            }
            else if (cmdToken.Equals("DENSE"))
            {
                boolPaintDensity = true;
            }
            else if (cmdToken.Equals("NO_DENSE"))
            {
                boolPaintDensity = false;
            }
            else if (cmdToken.Equals("TERM"))
            {
                boolPaintTerminalBlocks = true;
            }
            else if (cmdToken.Equals("NO_TERM"))
            {
                boolPaintTerminalBlocks = false;
            }
            else if (cmdToken.Equals("BLINK"))
            {
                boolBlinkForAlert = true;
            }
            else if (cmdToken.Equals("NO_BLINK"))
            {
                boolBlinkForAlert = false;
            }
            else if (cmdToken.Equals("ALERT"))
            {
                boolPaintAlertBlocks = true;
            }
            else if (cmdToken.Equals("NO_ALERT"))
            {
                boolPaintAlertBlocks = false;
            }
        }
    }

    if ((tmpGridAxisX / 2) == (tmpGridAxisY / 2))
    {
        return false;
    }

    if (tmpGridEndX &lt; tmpGridStartX)
    {
        int tmp = tmpGridStartX;
        tmpGridStartX = tmpGridEndX;
        tmpGridEndX = tmp;
    }

    if (tmpGridEndY &lt; tmpGridStartY)
    {
        int tmp = tmpGridStartY;
        tmpGridStartY = tmpGridEndY;
        tmpGridEndY = tmp;
    }

    if (tmpGridEndZ &lt; tmpGridStartZ)
    {
        int tmp = tmpGridStartZ;
        tmpGridStartZ = tmpGridEndZ;
        tmpGridEndZ = tmp;
    }

    if (tmpGridStartX &lt; Me.CubeGrid.Min.X)
    {
        tmpGridStartX = Me.CubeGrid.Min.X;
    }
    if (tmpGridEndX &gt; Me.CubeGrid.Max.X)
    {
        tmpGridEndX = Me.CubeGrid.Max.X;
    }
    if (tmpGridStartY &lt; Me.CubeGrid.Min.Y)
    {
        tmpGridStartY = Me.CubeGrid.Min.Y;
    }
    if (tmpGridEndY &gt; Me.CubeGrid.Max.Y)
    {
        tmpGridEndY = Me.CubeGrid.Max.Y;
    }
    if (tmpGridStartZ &lt; Me.CubeGrid.Min.Z)
    {
        tmpGridStartZ = Me.CubeGrid.Min.Z;
    }
    if (tmpGridEndZ &gt; Me.CubeGrid.Max.Z)
    {
        tmpGridEndZ = Me.CubeGrid.Max.Z;
    }
    
    if (tmpGridAxisX != gridAxisX || tmpGridAxisY != gridAxisY || tmpGridStartX != gridStartX || tmpGridEndX != gridEndX || tmpGridStartY != gridStartY || tmpGridEndY != gridEndY || tmpGridStartZ != gridStartZ || tmpGridEndZ != gridEndZ)
    {
        gridAxisX = tmpGridAxisX;
        gridAxisY = tmpGridAxisY;
        gridStartX = tmpGridStartX;
        gridEndX = tmpGridEndX;
        gridStartY = tmpGridStartY;
        gridEndY = tmpGridEndY;
        gridStartZ = tmpGridStartZ;
        gridEndZ = tmpGridEndZ;
        gridWidthX = gridEndX - gridStartX + 1;
        gridWidthY = gridEndY - gridStartY + 1;
        gridWidthZ = gridEndZ - gridStartZ + 1;

        return true;
    }
    else
    {
        return false;
    }
}

int ParseAxisToken(string token)
{
    switch (token)
    {
        case "X":
        case "+X":
            return 0;
        case "-X":
            return 1;
        case "Y":
        case "+Y":
            return 2;
        case "-Y":
            return 3;
        case "Z":
        case "+Z":
            return 4;
        case "-Z":
            return 5;
        default:
            return -1;
    }
}

string RetrieveAxisParameter(int gridAxis)
{
    switch (gridAxis)
    {
        case 0:
            return "X";
        case 1:
            return "-X";
        case 2:
            return "Y";
        case 3:
            return "-Y";
        case 4:
            return "Z";
        case 5:
            return "-Z";
        default:
            return "";
    }
}

void WriteDisplayParameters()
{
    StringBuilder sb = new StringBuilder();
    sb.Append("A_X:").Append(RetrieveAxisParameter(gridAxisX)).Append(',');
    sb.Append("A_Y:").Append(RetrieveAxisParameter(gridAxisY)).Append(',');
    sb.Append("X1:").Append(gridStartX).Append(',');
    sb.Append("X2:").Append(gridEndX).Append(',');
    sb.Append("Y1:").Append(gridStartY).Append(',');
    sb.Append("Y2:").Append(gridEndY).Append(',');
    sb.Append("Z1:").Append(gridStartZ).Append(',');
    sb.Append("Z2:").Append(gridEndZ).Append(',');
    sb.Append(boolUseRelativeDensity ? "RELDENSE" : "NO_RELDENSE").Append(',');
    sb.Append(boolPaintDensity ? "DENSE" : "NO_DENSE").Append(',');
    sb.Append(boolPaintTerminalBlocks ? "TERM" : "NO_TERM").Append(',');
    sb.Append(boolBlinkForAlert ? "BLINK" : "NO_BLINK").Append(',');
    sb.Append(boolPaintAlertBlocks ? "ALERT" : "NO_ALERT");

    displayPanel.WritePublicTitle(sb.ToString());
}

//------------------------------ Initialization Methods ------------------------------

void InitDisplayPanel()
{
    displayPanel = GridTerminalSystem.GetBlockWithName(strDisplayPanel) as IMyTextPanel;
    if (displayPanel == null)
    {
        throw new Exception("Error: No Text Panel named " + strDisplayPanel + " is detected.");
    }

    displayPanel.SetValue&lt;float&gt;("FontSize", 0.1f * PIXEL_SIZE);
    displayPanel.SetValue&lt;Color&gt;("FontColor", new Color(255, 255, 255));

    displayPanel.ShowTextureOnScreen();
    displayPanel.ShowPublicTextOnScreen();

    if (displayPanel.DefinitionDisplayNameText.ToUpper().Contains("WIDE"))
    {
        screenWidthX = WIDE_LCD_MAX_RESOLUTION_X / PIXEL_SIZE;
        screenWidthY = WIDE_LCD_MAX_RESOLUTION_Y / PIXEL_SIZE;
    }
    else
    {
        screenWidthX = TEXT_MAX_RESOLUTION_X / PIXEL_SIZE;
        screenWidthY = TEXT_MAX_RESOLUTION_Y / PIXEL_SIZE;
    }

    structureBase = new char[screenWidthY][];
    for (int i = 0; i &lt; screenWidthY; i++)
    {
        structureBase[i] = new char[screenWidthX];
        structureBase[i] = new string(chrBackground, screenWidthX).ToCharArray();
    }
}

void InitDisplayPanels()
{
    displayPanel = GridTerminalSystem.GetBlockWithName(strDisplayPanel) as IMyTextPanel;
    if (displayPanel == null)
    {
        throw new Exception("Error: No Text Panel named " + strDisplayPanel + " is detected.");
    }
    
    Vector3I panelLeftVector = -Base6Directions.GetIntVector(displayPanel.Orientation.Left);
    Vector3I panelDownVector = -Base6Directions.GetIntVector(displayPanel.Orientation.Up);

    Vector3I panelSize = displayPanel.Max - displayPanel.Min + new Vector3I(1, 1, 1);
    panelLeftVector = new Vector3I(panelLeftVector.X * panelSize.X, panelLeftVector.Y * panelSize.Y, panelLeftVector.Z * panelSize.Z);
    panelDownVector = new Vector3I(panelDownVector.X * panelSize.X, panelDownVector.Y * panelSize.Y, panelDownVector.Z * panelSize.Z);
    
    displayPanels = new IMyTextPanel[displayPanelVerticalCount][];
    for (int y = 0; y &lt; displayPanelVerticalCount; y++)
    {
        displayPanels[y] = new IMyTextPanel[displayPanelHorizontalCount];
        for (int x = 0; x &lt; displayPanelHorizontalCount; x++)
        {
            IMySlimBlock slimBlock = Me.CubeGrid.GetCubeBlock(displayPanel.Position + (x * panelLeftVector) + (y * panelDownVector));
            
            IMyTextPanel panel = (slimBlock == null ? null : slimBlock.FatBlock as IMyTextPanel);
            if (panel == null)
            {
                throw new Exception("Error: No Text Panel detected at " + x + " blocks right and " + y + " blocks down from " + strDisplayPanel);
            }
            displayPanels[y][x] = panel;

            displayPanels[y][x].SetValue&lt;float&gt;("FontSize", 0.1f * PIXEL_SIZE);
            displayPanels[y][x].SetValue&lt;Color&gt;("FontColor", new Color(255, 255, 255));

            displayPanels[y][x].ShowTextureOnScreen();
            displayPanels[y][x].ShowPublicTextOnScreen();
        }
    }
    
    if (displayPanel.DefinitionDisplayNameText.ToUpper().Contains("WIDE"))
    {
        screenWidthX = WIDE_LCD_MAX_RESOLUTION_X / PIXEL_SIZE * displayPanelHorizontalCount;
        screenWidthY = WIDE_LCD_MAX_RESOLUTION_Y / PIXEL_SIZE * displayPanelVerticalCount;
    }
    else
    {
        screenWidthX = TEXT_MAX_RESOLUTION_X / PIXEL_SIZE * displayPanelHorizontalCount;
        screenWidthY = TEXT_MAX_RESOLUTION_Y / PIXEL_SIZE * displayPanelVerticalCount;
    }

    structureBase = new char[screenWidthY][];
    for (int i = 0; i &lt; screenWidthY; i++)
    {
        structureBase[i] = new char[screenWidthX];
        structureBase[i] = new string(chrBackground, screenWidthX).ToCharArray();
    }
}

void InitScreenParameters()
{
    switch (gridAxisX)
    {
        case 0:
        case 1:
            axisWidthX = gridWidthX;
            break;
        case 2:
        case 3:
            axisWidthX = gridWidthY;
            break;
        case 4:
        case 5:
            axisWidthX = gridWidthZ;
            break;
        default:
            axisWidthX = gridWidthX;
            break;
    }
    
    switch (gridAxisY)
    {
        case 0:
        case 1:
            axisWidthY = gridWidthX;
            break;
        case 2:
        case 3:
            axisWidthY = gridWidthY;
            break;
        case 4:
        case 5:
            axisWidthY = gridWidthZ;
            break;
        default:
            axisWidthY = gridWidthZ;
            break;
    }

    if (axisWidthX == gridWidthX)
    {
        if (axisWidthY == gridWidthY)
        {
            axisWidthZ = gridWidthZ;
        }
        else
        {
            axisWidthZ = gridWidthY;
        }
    }
    else if (axisWidthX == gridWidthY)
    {
        if (axisWidthY == gridWidthX)
        {
            axisWidthZ = gridWidthZ;
        }
        else
        {
            axisWidthZ = gridWidthX;
        }
    }
    else
    {
        if (axisWidthY == gridWidthX)
        {
            axisWidthZ = gridWidthY;
        }
        else
        {
            axisWidthZ = gridWidthX;
        }
    }
    
    if (screenWidthX - axisWidthX - 1 &lt; 0)
    {
        TruncateAxisX(axisWidthX - screenWidthX + 1);
    }

    if (screenWidthY - axisWidthY - 1 &lt; 0)
    {
        TruncateAxisY(axisWidthY - screenWidthY + 1);
    }

    screenBlockSizeX = (screenWidthX - axisWidthX - 1) / axisWidthX;
    screenBlockSizeY = (screenWidthY - axisWidthY - 1) / axisWidthY;

    int maxScreenBlockSize = Math.Min(screenBlockSizeX, screenBlockSizeY);
    screenBlockSizeX = maxScreenBlockSize;
    screenBlockSizeY = maxScreenBlockSize;

    screenOffsetX = (screenWidthX - (screenBlockSizeX * axisWidthX) - axisWidthX - 1) / 2;
    screenOffsetY = (screenWidthY - (screenBlockSizeY * axisWidthY) - axisWidthY - 1) / 2;

    structureDensity = new Vector3I[axisWidthY][];
    for (int i = 0; i &lt; axisWidthY; i++)
    {
        structureDensity[i] = new Vector3I[axisWidthX];
    }
    
    switch (gridAxisX / 2)
    {
        case 0:
            gridAxisXDirection = Base6Directions.Axis.LeftRight;
            break;
        case 1:
            gridAxisXDirection = Base6Directions.Axis.UpDown;
            break;
        case 2:
            gridAxisXDirection = Base6Directions.Axis.ForwardBackward;
            break;
        default:
            gridAxisXDirection = Base6Directions.Axis.LeftRight;
            break;
    }
    
    switch (gridAxisY / 2)
    {
        case 0:
            gridAxisYDirection = Base6Directions.Axis.LeftRight;
            break;
        case 1:
            gridAxisYDirection = Base6Directions.Axis.UpDown;
            break;
        case 2:
            gridAxisYDirection = Base6Directions.Axis.ForwardBackward;
            break;
        default:
            gridAxisYDirection = Base6Directions.Axis.LeftRight;
            break;
    }

    List&lt;Base6Directions.Axis&gt; axisList = new List&lt;Base6Directions.Axis&gt;();
    axisList.Add(Base6Directions.Axis.LeftRight);
    axisList.Add(Base6Directions.Axis.UpDown);
    axisList.Add(Base6Directions.Axis.ForwardBackward);
    axisList.Remove(gridAxisXDirection);
    axisList.Remove(gridAxisYDirection);
    gridAxisZDirection = axisList[0];
    
    gridMin = new Vector3I(gridStartX, gridStartY, gridStartZ);
    gridMax = new Vector3I(gridEndX, gridEndY, gridEndZ);

    gridReverseX = (gridAxisX % 2 != 0);
    gridReverseY = (gridAxisY % 2 != 0);

    gridOffsetPosX = (gridReverseX ? gridMax.AxisValue(gridAxisXDirection) : gridMin.AxisValue(gridAxisXDirection));
    gridOffsetPosY = (gridReverseY ? gridMax.AxisValue(gridAxisYDirection) : gridMin.AxisValue(gridAxisYDirection));
}

void TruncateAxisX(int amount)
{
    bool reverseX = (gridAxisX % 2 != 0);
    axisWidthX -= amount;
    switch (gridAxisX)
    {
        case 0:
        case 1:
            gridWidthX = axisWidthX;
            if (reverseX)
            {
                gridStartX += amount;
            }
            else
            {
                gridEndX -= amount;
            }
            break;
        case 2:
        case 3:
            gridWidthY = axisWidthX;
            if (reverseX)
            {
                gridStartY += amount;
            }
            else
            {
                gridEndY -= amount;
            }
            break;
        case 4:
        case 5:
            gridWidthZ = axisWidthX;
            if (reverseX)
            {
                gridStartZ += amount;
            }
            else
            {
                gridEndZ -= amount;
            }
            break;
        default:
            gridWidthX = axisWidthX;
            if (reverseX)
            {
                gridStartX += amount;
            }
            else
            {
                gridEndX -= amount;
            }
            break;
    }
}

void TruncateAxisY(int amount)
{
    bool reverseY = (gridAxisY % 2 != 0);
    axisWidthY -= amount;
    switch (gridAxisY)
    {
        case 0:
        case 1:
            gridWidthX = axisWidthY;
            if (reverseY)
            {
                gridStartX += amount;
            }
            else
            {
                gridEndX -= amount;
            }
            break;
        case 2:
        case 3:
            gridWidthY = axisWidthY;
            if (reverseY)
            {
                gridStartY += amount;
            }
            else
            {
                gridEndY -= amount;
            }
            break;
        case 4:
        case 5:
            gridWidthZ = axisWidthY;
            if (reverseY)
            {
                gridStartZ += amount;
            }
            else
            {
                gridEndZ -= amount;
            }
            break;
        default:
            gridWidthZ = axisWidthY;
            if (reverseY)
            {
                gridStartZ += amount;
            }
            else
            {
                gridEndZ -= amount;
            }
            break;
    }
}

bool InitStructureData(IMyCubeGrid cubeGrid, Stack&lt;Vector3I&gt; remainingCubes, Dictionary&lt;Vector3I, byte&gt; foundCubes, HashSet&lt;Vector3I&gt; testedCubes, float instructionPercentLimit)
{
    int instructionLimit = (int)(instructionPercentLimit * Runtime.MaxInstructionCount);
    
    bool exists;
    byte adjacent;
    Vector3I nextCube;
    
    while (remainingCubes.Count &gt; 0 &amp;&amp; Runtime.CurrentInstructionCount &lt; instructionLimit)
    {
        Vector3I currentCube = remainingCubes.Pop();
        adjacent = 0;

        for (int i = 0; i &lt; 6; i++)
        {
            nextCube = currentCube + ADJACENT_VECTORS[i];
            if (testedCubes.Contains(nextCube))
            {
                if (foundCubes.ContainsKey(nextCube))
                {
                    adjacent |= ADJACENT_MASKS[i];
                }
            }
            else
            {
                testedCubes.Add(nextCube);
                exists = cubeGrid.CubeExists(nextCube);
                if (exists)
                {
                    remainingCubes.Push(nextCube);
                    foundCubes.Add(nextCube, 0);
                    adjacent |= ADJACENT_MASKS[i];
                }
            }
        }
        
        foundCubes[currentCube] = adjacent;
    }

    return (remainingCubes.Count == 0);
}

void InitTerminalBlocks()
{
    terminalBlocks = new List&lt;IMyTerminalBlock&gt;();
    GridTerminalSystem.GetBlocks(terminalBlocks);
}

int ComputeStructureDensity(List&lt;KeyValuePair&lt;Vector3I, byte&gt;&gt; blocksList, int index, float instructionPercentLimit)
{
    int instructionLimit = (int)(instructionPercentLimit * Runtime.MaxInstructionCount);
    
    while (index &lt; blocksList.Count &amp;&amp; Runtime.CurrentInstructionCount &lt; instructionLimit)
    {
        KeyValuePair&lt;Vector3I, byte&gt; nextBlock = blocksList[index];
        
        int screenPosX = (gridReverseX ? gridOffsetPosX - nextBlock.Key.AxisValue(gridAxisXDirection) : nextBlock.Key.AxisValue(gridAxisXDirection) - gridOffsetPosX);
        int screenPosY = (gridReverseY ? gridOffsetPosY - nextBlock.Key.AxisValue(gridAxisYDirection) : nextBlock.Key.AxisValue(gridAxisYDirection) - gridOffsetPosY);

        int depthPosZ = nextBlock.Key.AxisValue(gridAxisZDirection);
        Vector3I densityPoint = structureDensity[screenPosY][screenPosX];
        if (densityPoint.Z == 0)
        {
            structureDensity[screenPosY][screenPosX] = new Vector3I(depthPosZ, depthPosZ, 1);
        }
        else
        {
            structureDensity[screenPosY][screenPosX] = new Vector3I(Math.Min(densityPoint.X, depthPosZ), Math.Max(densityPoint.Y, depthPosZ), densityPoint.Z + 1);
        }

        index++;
    }

    return index;
}

bool FilteringRequired()
{
    return gridStartX &gt; Me.CubeGrid.Min.X || gridEndX &lt; Me.CubeGrid.Max.X ||
        gridStartY &gt; Me.CubeGrid.Min.Y || gridEndY &lt; Me.CubeGrid.Max.Y ||
        gridStartZ &gt; Me.CubeGrid.Min.Z || gridEndZ &lt; Me.CubeGrid.Max.Z;
}

int FilterStructureData(IMyCubeGrid cubeGrid, List&lt;KeyValuePair&lt;Vector3I, byte&gt;&gt; blocksList, List&lt;KeyValuePair&lt;Vector3I, byte&gt;&gt; filteredList, int index, float instructionPercentLimit)
{
    int instructionLimit = (int)(instructionPercentLimit * Runtime.MaxInstructionCount);
    
    while (index &lt; blocksList.Count &amp;&amp; Runtime.CurrentInstructionCount &lt; instructionLimit)
    {
        KeyValuePair&lt;Vector3I, byte&gt; nextBlock = blocksList[index];
        
        if (Vector3I.BoxContains(gridMin, gridMax, nextBlock.Key))
        {
            filteredList.Add(nextBlock);
        }
        
        index++;
    }

    return index;
}

int FilterWatchedBlocks(IMyCubeGrid grid, List&lt;IMyTerminalBlock&gt; blockList, List&lt;IMyTerminalBlock&gt; watchedList, int index, float instructionPercentLimit)
{
    int instructionLimit = (int)(instructionPercentLimit * Runtime.MaxInstructionCount);
    
    while (index &lt; blockList.Count &amp;&amp; Runtime.CurrentInstructionCount &lt; instructionLimit)
    {
        IMyTerminalBlock nextBlock = blockList[index];
        
        if (Vector3I.BoxContains(gridMin, gridMax, nextBlock.Position) &amp;&amp; nextBlock.CubeGrid == grid)
        {
            if (WATCH_BLOCK_LOOKUP.Contains(nextBlock.DefinitionDisplayNameText))
            {
                watchedList.Add(nextBlock);
            }
        }
        
        index++;
    }

    return index;
}

//------------------------------ Paint Methods ------------------------------

int PaintStructureBase(List&lt;KeyValuePair&lt;Vector3I, byte&gt;&gt; blockList, int index, float instructionPercentLimit)
{
    int instructionLimit = (int)(instructionPercentLimit * Runtime.MaxInstructionCount);
    
    byte drawLeftMask = ADJACENT_MASKS[gridAxisX];
    byte drawRightMask = ADJACENT_MASKS[((gridAxisX / 2) * 2) + 1 - (gridAxisX % 2)];
    byte drawTopMask = ADJACENT_MASKS[gridAxisY];
    byte drawBottomMask = ADJACENT_MASKS[((gridAxisY / 2) * 2) + 1 - (gridAxisY % 2)];
    
    while (index &lt; blockList.Count &amp;&amp; Runtime.CurrentInstructionCount &lt; instructionLimit)
    {
        KeyValuePair&lt;Vector3I, byte&gt; nextBlock = blockList[index];
        
        int screenPosX = (gridReverseX ? gridOffsetPosX - nextBlock.Key.AxisValue(gridAxisXDirection) : nextBlock.Key.AxisValue(gridAxisXDirection) - gridOffsetPosX);
        int screenPosY = (gridReverseY ? gridOffsetPosY - nextBlock.Key.AxisValue(gridAxisYDirection) : nextBlock.Key.AxisValue(gridAxisYDirection) - gridOffsetPosY);

        bool drawLeft = ((nextBlock.Value &amp; drawLeftMask) == 0);
        bool drawRight = ((nextBlock.Value &amp; drawRightMask) == 0);
        bool drawTop = ((nextBlock.Value &amp; drawTopMask) == 0);
        bool drawBottom = ((nextBlock.Value &amp; drawBottomMask) == 0);
        
        int markerX = 0;
        int markerY = 0;
        int markerX1 = 0;
        int markerY1 = 0;

        if (drawLeft || drawRight || drawTop)
        {
            markerY = screenOffsetY + (screenPosY * (screenBlockSizeY + 1));
        }
        if (drawBottom)
        {
            markerY1 = screenOffsetY + ((screenPosY + 1) * (screenBlockSizeY + 1));
        }
        if (drawLeft || drawTop || drawBottom)
        {
            markerX = screenOffsetX + (screenPosX * (screenBlockSizeX + 1));
        }
        if (drawRight)
        {
            markerX1 = screenOffsetX + ((screenPosX + 1) * (screenBlockSizeX + 1));
        }

        if (drawLeft)
        {
            for (int y = 0; y &lt;= screenBlockSizeY + 1; y++)
            {
                structureBase[markerY + y][markerX] = chrStructure;
            }
        }

        if (drawRight)
        {
            for (int y = 0; y &lt;= screenBlockSizeY + 1; y++)
            {
                structureBase[markerY + y][markerX1] = chrStructure;
            }
        }

        if (drawTop)
        {
            for (int x = 0; x &lt;= screenBlockSizeX + 1; x++)
            {
                structureBase[markerY][markerX + x] = chrStructure;
            }
        }

        if (drawBottom)
        {
            for (int x = 0; x &lt;= screenBlockSizeX + 1; x++)
            {
                structureBase[markerY1][markerX + x] = chrStructure;
            }
        }
        
        index++;
    }

    return index;
}

int PaintStructureDensity(Vector3I[][] densityMap, int index, float instructionPercentLimit)
{
    int instructionLimit = (int)(instructionPercentLimit * Runtime.MaxInstructionCount);
    
    int totalIndex = axisWidthY * axisWidthX;
    
    while (index &lt; totalIndex &amp;&amp; Runtime.CurrentInstructionCount &lt; instructionLimit)
    {
        int screenPosX = index % axisWidthX;
        int screenPosY = index / axisWidthX;
        
        Vector3I densityPoint = densityMap[screenPosY][screenPosX];
        if (densityPoint.Z &gt; 0)
        {
            int densityMax = (boolUseRelativeDensity ? densityPoint.Y - densityPoint.X + 1 : axisWidthZ);
            if (densityPoint.Z == densityMax)
            {
                PaintSolidBox(structureBase, screenPosX, screenPosY, chrStructure);
            }
            else if (densityPoint.Z &gt;= Math.Ceiling(densityMax * densityThreshold))
            {
                PaintSolidBox(structureBase, screenPosX, screenPosY, chrDensity);
            }
            else if (densityPoint.Z &gt;= Math.Ceiling(densityMax * lowDensityThreshold))
            {
                PaintSolidBox(structureBase, screenPosX, screenPosY, chrLowDensity);
            }
        }

        index++;
    }

    return index;
}

int PaintMissingStructure(char[][] displayMap, IMyCubeGrid grid, List&lt;KeyValuePair&lt;Vector3I, byte&gt;&gt; blockList, HashSet&lt;Vector2I&gt; drawnPositions, int index, float instructionPercentLimit)
{
    int instructionLimit = (int)(instructionPercentLimit * Runtime.MaxInstructionCount);
    
    while (index &lt; blockList.Count &amp;&amp; Runtime.CurrentInstructionCount &lt; instructionLimit)
    {
        KeyValuePair&lt;Vector3I, byte&gt; nextBlock = blockList[index];
        
        if (grid.CubeExists(nextBlock.Key))
        {
            index++;
            continue;
        }
        
        int screenPosX = (gridReverseX ? gridOffsetPosX - nextBlock.Key.AxisValue(gridAxisXDirection) : nextBlock.Key.AxisValue(gridAxisXDirection) - gridOffsetPosX);
        int screenPosY = (gridReverseY ? gridOffsetPosY - nextBlock.Key.AxisValue(gridAxisYDirection) : nextBlock.Key.AxisValue(gridAxisYDirection) - gridOffsetPosY);
        
        Vector2I screenPosition = new Vector2I(screenPosX, screenPosY);

        if (!drawnPositions.Contains(screenPosition))
        {
            PaintHollowBox(displayMap, screenPosX, screenPosY, chrMissingBlock);

            drawnPositions.Add(screenPosition);
        }

        index++;
    }

    return index;
}

int PaintGoodTerminalBlocks(char[][] displayMap, IMyCubeGrid grid, List&lt;IMyTerminalBlock&gt; blockList, Dictionary&lt;Vector4I, int&gt; priorityDrawn, List&lt;Vector4I&gt; damagedBlocks, List&lt;Vector4I&gt; criticalBlocks, int index, float instructionPercentLimit)
{
    int instructionLimit = (int)(instructionPercentLimit * Runtime.MaxInstructionCount);
    
    while (index &lt; blockList.Count &amp;&amp; Runtime.CurrentInstructionCount &lt; instructionLimit)
    {
        IMyTerminalBlock nextBlock = blockList[index];
        
        if (Vector3I.BoxContains(gridMin, gridMax, nextBlock.Position) &amp;&amp; nextBlock.CubeGrid == grid)
        {
            if (nextBlock.Min == nextBlock.Max)
            {
                int screenPosX = (gridReverseX ? gridOffsetPosX - nextBlock.Position.AxisValue(gridAxisXDirection) : nextBlock.Position.AxisValue(gridAxisXDirection) - gridOffsetPosX);
                int screenPosY = (gridReverseY ? gridOffsetPosY - nextBlock.Position.AxisValue(gridAxisYDirection) : nextBlock.Position.AxisValue(gridAxisYDirection) - gridOffsetPosY);
            
                Vector4I boxBoundary = new Vector4I(screenPosX, screenPosY, screenPosX, screenPosY);
            
                int takenPriority = priorityDrawn.GetValueOrDefault&lt;Vector4I, int&gt;(boxBoundary, 0);

                if (nextBlock.IsFunctional)
                {
                    if (takenPriority == 0)
                    {
                        PaintHollowBox(displayMap, screenPosX, screenPosY, chrTerminalBlockFunctional);
                        priorityDrawn[boxBoundary] = 1;
                    }
                }
                else if (grid.CubeExists(nextBlock.Position))
                {
                    if (takenPriority &lt;= 1)
                    {
                        damagedBlocks.Add(boxBoundary);
                        priorityDrawn[boxBoundary] = 2;
                    }
                }
                else
                {
                    if (takenPriority &lt;= 2)
                    {
                        criticalBlocks.Add(boxBoundary);
                        priorityDrawn[boxBoundary] = 3;
                    }
                }
            }
            else
            {
                int screenPosX1 = (gridReverseX ? gridOffsetPosX - nextBlock.Min.AxisValue(gridAxisXDirection) : nextBlock.Min.AxisValue(gridAxisXDirection) - gridOffsetPosX);
                int screenPosY1 = (gridReverseY ? gridOffsetPosY - nextBlock.Min.AxisValue(gridAxisYDirection) : nextBlock.Min.AxisValue(gridAxisYDirection) - gridOffsetPosY);
                int screenPosX2 = (gridReverseX ? gridOffsetPosX - nextBlock.Max.AxisValue(gridAxisXDirection) : nextBlock.Max.AxisValue(gridAxisXDirection) - gridOffsetPosX);
                int screenPosY2 = (gridReverseY ? gridOffsetPosY - nextBlock.Max.AxisValue(gridAxisYDirection) : nextBlock.Max.AxisValue(gridAxisYDirection) - gridOffsetPosY);
                
                if (screenPosX1 &gt; screenPosX2)
                {
                    int tempPosX1 = screenPosX1;
                    screenPosX1 = screenPosX2;
                    screenPosX2 = tempPosX1;
                }

                if (screenPosY1 &gt; screenPosY2)
                {
                    int tempPosY1 = screenPosY1;
                    screenPosY1 = screenPosY2;
                    screenPosY2 = tempPosY1;
                }

                screenPosX1 = Math.Max(screenPosX1, 0);
                screenPosY1 = Math.Max(screenPosY1, 0);
                screenPosX2 = Math.Min(screenPosX2, axisWidthX - 1);
                screenPosY2 = Math.Min(screenPosY2, axisWidthY - 1);

                Vector4I boxBoundary = new Vector4I(screenPosX1, screenPosY1, screenPosX2, screenPosY2);

                int takenPriority = priorityDrawn.GetValueOrDefault&lt;Vector4I, int&gt;(boxBoundary, 0);

                if (nextBlock.IsFunctional)
                {
                    if (takenPriority == 0)
                    {
                        PaintHollowBox(displayMap, screenPosX1, screenPosY1, screenPosX2, screenPosY2, chrTerminalBlockFunctional);
                        priorityDrawn[boxBoundary] = 1;
                    }
                }
                else if (grid.CubeExists(nextBlock.Position))
                {
                    if (takenPriority &lt;= 1)
                    {
                        damagedBlocks.Add(boxBoundary);
                        priorityDrawn[boxBoundary] = 2;
                    }
                }
                else
                {
                    if (takenPriority &lt;= 2)
                    {
                        criticalBlocks.Add(boxBoundary);
                        priorityDrawn[boxBoundary] = 3;
                    }
                }
            }
        }

        index++;
    }

    return index;
}

int PaintBadTerminalBlocks(char[][] displayMap, IMyCubeGrid grid, List&lt;Vector4I&gt; damagedBlocks, List&lt;Vector4I&gt; criticalBlocks, int index, float instructionPercentLimit)
{
    int instructionLimit = (int)(instructionPercentLimit * Runtime.MaxInstructionCount);
    
    while (index &lt; damagedBlocks.Count + criticalBlocks.Count &amp;&amp; Runtime.CurrentInstructionCount &lt; instructionLimit)
    {
        bool isDamaged = index &lt; damagedBlocks.Count;
        Vector4I boxBoundary = (isDamaged ? damagedBlocks[index] : criticalBlocks[index - damagedBlocks.Count]);
        
        if (boxBoundary.X != boxBoundary.Z || boxBoundary.Y != boxBoundary.W)
        {
            PaintHollowBox(displayMap, boxBoundary.X, boxBoundary.Y, boxBoundary.Z, boxBoundary.W, isDamaged ? chrTerminalBlockDamaged : chrTerminalBlockMissing);
        }
        else
        {
            PaintHollowBox(displayMap, boxBoundary.X, boxBoundary.Y, isDamaged ? chrTerminalBlockDamaged : chrTerminalBlockMissing);
        }

        index++;
    }

    return index;
}

int PaintWatchedBlocks(char[][] displayMap, IMyCubeGrid grid, List&lt;IMyTerminalBlock&gt; blockList, int index, float instructionPercentLimit)
{
    int instructionLimit = (int)(instructionPercentLimit * Runtime.MaxInstructionCount);
    
    while (index &lt; blockList.Count &amp;&amp; Runtime.CurrentInstructionCount &lt; instructionLimit)
    {
        IMyTerminalBlock nextBlock = blockList[index];
        
        bool needAlert = false;

        if ((nextBlock as IMyAirVent) != null)
        {
            needAlert = (nextBlock as IMyAirVent).GetOxygenLevel() &lt; 0.99f;
        }
        else if ((nextBlock as IMyLargeTurretBase) != null)
        {
            needAlert = (nextBlock as IMyLargeTurretBase).IsShooting;
        }
        else if ((nextBlock as IMySensorBlock) != null)
        {
            needAlert = false;

            IMySensorBlock sensorBlock = (nextBlock as IMySensorBlock);
            if (sensorBlock.LastDetectedEntity != null)
            {
                Vector3I detectedPosition = grid.WorldToGridInteger(sensorBlock.LastDetectedEntity.GetPosition());
                
                int screenPosX = (gridReverseX ? gridOffsetPosX - detectedPosition.AxisValue(gridAxisXDirection) : detectedPosition.AxisValue(gridAxisXDirection) - gridOffsetPosX);
                int screenPosY = (gridReverseY ? gridOffsetPosY - detectedPosition.AxisValue(gridAxisYDirection) : detectedPosition.AxisValue(gridAxisYDirection) - gridOffsetPosY);
                
                if (screenPosX &gt;= 0 &amp;&amp; screenPosX &lt; axisWidthX &amp;&amp; screenPosY &gt;= 0 &amp;&amp; screenPosY &lt; axisWidthY)
                {
                    PaintSolidBox(displayMap, screenPosX, screenPosY, chrDetectedEntity);
                }
            }
        }
        
        if (needAlert)
        {
            if (nextBlock.Min == nextBlock.Max)
            {
                int screenPosX = (gridReverseX ? gridOffsetPosX - nextBlock.Position.AxisValue(gridAxisXDirection) : nextBlock.Position.AxisValue(gridAxisXDirection) - gridOffsetPosX);
                int screenPosY = (gridReverseY ? gridOffsetPosY - nextBlock.Position.AxisValue(gridAxisYDirection) : nextBlock.Position.AxisValue(gridAxisYDirection) - gridOffsetPosY);

                PaintSolidBox(displayMap, screenPosX, screenPosY, chrAlertBlock);
            }
            else
            {
                int screenPosX1 = (gridReverseX ? gridOffsetPosX - nextBlock.Min.AxisValue(gridAxisXDirection) : nextBlock.Min.AxisValue(gridAxisXDirection) - gridOffsetPosX);
                int screenPosY1 = (gridReverseY ? gridOffsetPosY - nextBlock.Min.AxisValue(gridAxisYDirection) : nextBlock.Min.AxisValue(gridAxisYDirection) - gridOffsetPosY);
                int screenPosX2 = (gridReverseX ? gridOffsetPosX - nextBlock.Max.AxisValue(gridAxisXDirection) : nextBlock.Max.AxisValue(gridAxisXDirection) - gridOffsetPosX);
                int screenPosY2 = (gridReverseY ? gridOffsetPosY - nextBlock.Max.AxisValue(gridAxisYDirection) : nextBlock.Max.AxisValue(gridAxisYDirection) - gridOffsetPosY);

                screenPosX1 = Math.Max(screenPosX1, 0);
                screenPosY1 = Math.Max(screenPosY1, 0);
                screenPosX2 = Math.Min(screenPosX2, axisWidthX - 1);
                screenPosY2 = Math.Min(screenPosY2, axisWidthY - 1);

                PaintSolidBox(displayMap, screenPosX1, screenPosY1, screenPosX2, screenPosY2, chrAlertBlock);
            }
        }

        index++;
    }

    return index;
}

void PaintSolidBox(char[][] displayMap, int posX, int posY, char chrPaint)
{
    int markerX = screenOffsetX + (posX * (screenBlockSizeX + 1));
    int markerY = screenOffsetY + (posY * (screenBlockSizeY + 1));
    
    for (int x = 0; x &lt;= screenBlockSizeX + 1; x++)
    {
        for (int y = 0; y &lt;= screenBlockSizeY + 1; y++)
        {
            displayMap[markerY + y][markerX + x] = chrPaint;
        }
    }
}

void PaintSolidBox(char[][] displayMap, int posX1, int posY1, int posX2, int posY2, char chrPaint)
{
    int markerX = screenOffsetX + (posX1 * (screenBlockSizeX + 1));
    int markerY = screenOffsetY + (posY1 * (screenBlockSizeY + 1));

    int maxMarkerX = (posX2 - posX1 + 1) * (screenBlockSizeX + 1);
    int maxMarkerY = (posY2 - posY1 + 1) * (screenBlockSizeY + 1);

    for (int x = 0; x &lt;= maxMarkerX; x++)
    {
        for (int y = 0; y &lt;= maxMarkerY; y++)
        {
            displayMap[markerY + y][markerX + x] = chrPaint;
        }
    }
}

void PaintHollowBox(char[][] displayMap, int posX, int posY, char chrPaint)
{
    int markerX = screenOffsetX + (posX * (screenBlockSizeX + 1));
    int markerY = screenOffsetY + (posY * (screenBlockSizeY + 1));

    for (int x = 0; x &lt;= screenBlockSizeX + 1; x++)
    {
        displayMap[markerY][markerX + x] = chrPaint;
        displayMap[markerY + screenBlockSizeY + 1][markerX + x] = chrPaint;
    }

    for (int y = 0; y &lt;= screenBlockSizeY + 1; y++)
    {
        displayMap[markerY + y][markerX] = chrPaint;
        displayMap[markerY + y][markerX + screenBlockSizeX + 1] = chrPaint;
    }
}

void PaintHollowBox(char[][] displayMap, int posX1, int posY1, int posX2, int posY2, char chrPaint)
{
    int markerX = screenOffsetX + (posX1 * (screenBlockSizeX + 1));
    int markerY = screenOffsetY + (posY1 * (screenBlockSizeY + 1));

    int maxMarkerX = (posX2 - posX1 + 1) * (screenBlockSizeX + 1);
    int maxMarkerY = (posY2 - posY1 + 1) * (screenBlockSizeY + 1);

    for (int x = 0; x &lt;= maxMarkerX; x++)
    {
        displayMap[markerY][markerX + x] = chrPaint;
        displayMap[markerY + maxMarkerY][markerX + x] = chrPaint;
    }

    for (int y = 0; y &lt;= maxMarkerY; y++)
    {
        displayMap[markerY + y][markerX] = chrPaint;
        displayMap[markerY + y][markerX + maxMarkerX] = chrPaint;
    }
}</Program>
