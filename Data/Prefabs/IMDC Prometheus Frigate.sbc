Add("HandDrill3Item", "Tool", 0, "** Prof. Drill"); 
Add("HandDrill4Item", "Tool", 0, "*** Elite Drill"); 
Add("Construction", "Component", 50000); 
Add("MetalGrid", "Component", 15500, "Metal Grid"); 
Add("InteriorPlate", "Component", 55000, "Interior Plate"); 
